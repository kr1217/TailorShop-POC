# ── Root-level Docker Compose Secrets — TEMPLATE ─────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# MongoDB root credentials (used to initialize the database)
MONGO_ROOT_USER=your_mongo_root_user
MONGO_ROOT_PASS=your_secure_mongo_password

# Database name
MONGO_DB=tailor-poc

# Frontend public URL (for CORS on the backend)
FRONTEND_URL=http://your-domain.com

# Next.js public API URL (baked into frontend at build time)
NEXT_PUBLIC_API_URL=http://your-domain.com:5000/api
