# ── Root-level Docker Compose Secrets — TEMPLATE ─────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# MySQL credentials (used to initialize the database container)
MYSQL_ROOT_PASS=your_secure_root_password
MYSQL_USER=your_mysql_user
MYSQL_PASS=your_mysql_password
MYSQL_DB=tailor_poc

# Default admin login (seeded on first startup if no users exist in DB)
ADMIN_USER=admin
ADMIN_PASS=admin123

# Frontend public URL (for CORS on the backend)
FRONTEND_URL=http://your-domain.com

# Next.js public API URL (baked into frontend at build time)
NEXT_PUBLIC_API_URL=http://your-domain.com:5000/api

# Google Drive backup credentials
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token
