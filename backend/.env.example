# ── Backend Environment Variables — TEMPLATE ──────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# Server
NODE_ENV=production
PORT=5000

# MongoDB — use docker service name 'mongodb' when running in Docker
MONGODB_URI=mongodb://<MONGO_USER>:<MONGO_PASS>@mongodb:27017/tailor-poc?authSource=admin

# CORS — set to your frontend's public URL (no trailing slash)
FRONTEND_URL=http://your-domain.com

# Admin credentials for the mock auth endpoint
ADMIN_USER=your_admin_username
ADMIN_PASS=your_secure_password
